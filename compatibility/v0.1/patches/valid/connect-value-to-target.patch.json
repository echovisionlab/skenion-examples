{
  "schema": "skenion.graph.patch",
  "schemaVersion": "0.1.0",
  "id": "example_patch_connect_value_to_target",
  "baseRevision": "1",
  "clientId": "skenion-examples",
  "ops": [
    {
      "op": "addNode",
      "node": {
        "id": "target_2",
        "kind": "core.float",
        "kindVersion": "0.1.0",
        "params": {},
        "ports": [
          {
            "id": "in",
            "direction": "input",
            "label": "In",
            "type": {
              "flow": "event",
              "dataKind": "message.any"
            },
            "required": false,
            "activation": "trigger"
          },
          {
            "id": "cold",
            "direction": "input",
            "label": "Cold",
            "type": {
              "flow": "value",
              "dataKind": "number.float",
              "format": "f32"
            },
            "required": false,
            "activation": "latched"
          },
          {
            "id": "value",
            "direction": "output",
            "label": "Value",
            "type": {
              "flow": "value",
              "dataKind": "number.float",
              "format": "f32"
            }
          }
        ]
      }
    },
    {
      "op": "addEdge",
      "edge": {
        "from": {
          "node": "value_1",
          "port": "value"
        },
        "to": {
          "node": "target_2",
          "port": "in"
        }
      }
    }
  ]
}
