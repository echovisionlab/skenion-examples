        "id": "shader_1",
        "kind": "render.fullscreen-shader",
        "kindVersion": "0.1.0",
        "params": {
          "language": "wgsl",
          "source": "struct SkenionFrame {\n  resolution: vec2<f32>,\n  time: f32,\n  frame: u32,\n  u_value: f32,\n  u_value2: f32,\n  _pad0: vec2<f32>,\n  u_color: vec4<f32>,\n}\n\n@group(0) @binding(0)\nvar<uniform> skenion: SkenionFrame;\n\nstruct VertexOut {\n  @builtin(position) position: vec4<f32>,\n}\n\n@vertex\nfn vs_main(@builtin(vertex_index) vertex_index: u32) -> VertexOut {\n  var positions = array<vec2<f32>, 3>(\n    vec2<f32>(-1.0, -3.0),\n    vec2<f32>(-1.0,  1.0),\n    vec2<f32>( 3.0,  1.0)\n  );\n\n  var out: VertexOut;\n  out.position = vec4<f32>(positions[vertex_index], 0.0, 1.0);\n  return out;\n}\n\n@fragment\nfn fs_main() -> @location(0) vec4<f32> {\n  let pulse = 0.5 + 0.5 * sin(skenion.time + skenion.u_value2 * 6.28318);\n  let gradient = vec3<f32>(skenion.u_value, skenion.u_value2, 1.0 - skenion.u_value);\n  return vec4<f32>(mix(gradient, skenion.u_color.rgb, pulse * 0.35), skenion.u_color.a);\n}"
        },
