        "id": "shader_1",
        "kind": "render.fullscreen-shader",
        "kindVersion": "0.1.0",
        "params": {
          "language": "wgsl",
          "source": "// @skenion.uniform speed number.f32 default=0.25 min=0 max=1 step=0.01\n// @skenion.uniform phase number.f32 default=0.65 min=0 max=1 step=0.01\n// @skenion.uniform tint color.rgba default=[0.95,0.25,0.12,1]\n@fragment\nfn fs_main() -> @location(0) vec4<f32> {\n  let pulse = 0.5 + 0.5 * sin(skenion.time + skenion.phase * 6.28318);\n  let gradient = vec3<f32>(skenion.speed, skenion.phase, 1.0 - skenion.speed);\n  return vec4<f32>(mix(gradient, skenion.tint.rgb, pulse * 0.35), skenion.tint.a);\n}"
        },
