{
  "schema": "skenion.runtime.session-smoke.fixture",
  "schemaVersion": "0.1.0",
  "scenario": "same-session-multi-view-event-replay",
  "title": "Invalid replay session mismatch",
  "description": "The expected replay event points at a different session than the stream source, which would conflate same-session multi-view replay with a separate session.",
  "expectedInvalidReason": "expected event sessionId must match session.id",
  "runtime": {
    "requiresCapabilities": [
      "session.load",
      "session.addressing",
      "session.mutate",
      "session.events.stream",
      "session.events.replay"
    ]
  },
  "clients": [
    "view-a",
    "view-b"
  ],
  "session": {
    "id": "m06-8-invalid-session-a-{runId}",
    "project": "compatibility/v0.1/projects/valid/minimal-value.project.json",
    "patch": "compatibility/v0.1/patches/valid/set-value-param.patch.json"
  },
  "expect": {
    "event": {
      "kind": "mutate",
      "afterCursor": "loaded",
      "replayed": true,
      "sessionId": "m06-8-invalid-session-b-{runId}"
    }
  }
}
