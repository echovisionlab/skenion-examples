{
  "schema": "skenion.runtime.session-smoke.fixture",
  "schemaVersion": "0.1.0",
  "scenario": "same-session-multi-view-event-replay",
  "title": "Same session multi-view replay after mutation",
  "description": "Models two Studio windows attached to one Runtime session: one view captures the event cursor, another view mutates the graph, and the first view reconnects with the cursor to replay the mutation event.",
  "runtime": {
    "requiresCapabilities": [
      "session.load",
      "session.project",
      "session.addressing",
      "session.info",
      "session.mutate",
      "session.events.stream",
      "session.events.replay",
      "session.history"
    ]
  },
  "clients": [
    "view-a",
    "view-b"
  ],
  "session": {
    "id": "m06-8-same-view-{runId}",
    "project": "compatibility/v0.1/projects/valid/minimal-value.project.json",
    "patch": "compatibility/v0.1/patches/valid/set-value-param.patch.json"
  },
  "expect": {
    "event": {
      "kind": "mutate",
      "afterCursor": "loaded",
      "replayed": true,
      "sessionId": "m06-8-same-view-{runId}",
      "snapshotRevisionMatchesMutation": true
    },
    "alsoAcceptsLastEventId": true
  }
}
