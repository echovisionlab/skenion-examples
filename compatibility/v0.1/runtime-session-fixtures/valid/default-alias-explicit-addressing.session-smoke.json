{
  "schema": "skenion.runtime.session-smoke.fixture",
  "schemaVersion": "0.1.0",
  "scenario": "default-alias-explicit-addressing",
  "title": "Default session alias shares the explicit default session",
  "description": "Loads the default session through /v0/session and verifies /v0/sessions/default exposes the same snapshot and session info contract.",
  "runtime": {
    "requiresCapabilities": [
      "session.load",
      "session.project",
      "session.addressing",
      "session.defaultAlias",
      "session.info",
      "session.events.replay"
    ]
  },
  "defaultSession": {
    "id": "default",
    "aliasPath": "/v0/session",
    "explicitPathTemplate": "/v0/sessions/{sessionId}",
    "infoPathTemplate": "/v0/sessions/{sessionId}/info",
    "project": "compatibility/v0.1/projects/valid/minimal-value.project.json"
  },
  "expect": {
    "sharedSnapshot": true,
    "sessionId": "default",
    "graphId": "minimal-value-graph",
    "capabilities": {
      "sessionAddressing": true,
      "defaultSessionAlias": true,
      "eventReplay": true,
      "multiWindow": true
    }
  }
}
