{
  "schema": "skenion.node.definition",
  "schemaVersion": "0.1.0",
  "id": "adapter.gpu-texture-to-render-frame",
  "version": "0.1.0",
  "displayName": "GPU Texture to Render Frame",
  "category": "Adapter",
  "ports": [
    {
      "id": "texture",
      "direction": "input",
      "type": "value.core.tensor",
      "rate": "gpu"
    },
    {
      "id": "frame",
      "direction": "output",
      "type": "value.core.tensor",
      "rate": "render"
    }
  ],
  "execution": {
    "model": "gpu_pass",
    "clock": "frame"
  },
  "state": {
    "persistent": false
  },
  "permissions": [],
  "capabilities": [
    "adapter.explicit.v0.1"
  ]
}
