{
  "schema": "skenion.runtime.operation",
  "schemaVersion": "0.1.0",
  "id": "op-reject-outside-endpoint",
  "kind": "pasteGraphFragment",
  "request": {
    "target": {
      "path": {
        "kind": "root"
      },
      "baseRevision": "root-rev-1"
    },
    "fragment": {
      "schema": "skenion.graph.fragment",
      "schemaVersion": "0.2.0",
      "id": "fragment-rejected-outside-endpoint",
      "nodes": [
        {
          "id": "source",
          "kind": "core.value-number",
          "kindVersion": "0.2.0",
          "params": {
            "value": 1
          },
          "ports": [
            {
              "id": "out",
              "direction": "output",
              "type": "value.number",
              "rate": "control"
            }
          ]
        }
      ],
      "edges": [
        {
          "id": "edge_to_outside",
          "source": {
            "nodeId": "source",
            "portId": "out"
          },
          "target": {
            "nodeId": "outside",
            "portId": "in"
          },
          "resolvedType": "value.number"
        }
      ]
    },
    "options": {
      "outsideEndpointPolicy": "reject"
    }
  }
}
