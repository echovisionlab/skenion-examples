{
  "schema": "skenion.runtime.operation",
  "schemaVersion": "0.1.0",
  "id": "op-paste-boundary-node-into-project-patch",
  "kind": "pasteGraphFragment",
  "request": {
    "target": {
      "path": {
        "kind": "project-patch-definition",
        "patchId": "two_in_three_out"
      },
      "baseRevision": "patch-rev-1"
    },
    "fragment": {
      "schema": "skenion.graph.fragment",
      "schemaVersion": "0.2.0",
      "id": "fragment-new-boundary-inlet",
      "metadata": {
        "source": "palette",
        "purpose": "Paste a boundary node into a patch definition surface."
      },
      "nodes": [
        {
          "id": "mod_in",
          "kind": "core.inlet",
          "kindVersion": "0.2.0",
          "params": {
            "portId": "mod",
            "label": "Mod"
          },
          "ports": [
            {
              "id": "out",
              "direction": "output",
              "type": "value.number",
              "rate": "control",
              "description": "Modulation value entering the patch."
            }
          ]
        }
      ],
      "edges": [],
      "view": {
        "nodes": {
          "mod_in": {
            "x": 96,
            "y": 320
          }
        }
      }
    },
    "placement": {
      "kind": "anchor",
      "nodeId": "right_in",
      "offsetX": 0,
      "offsetY": 120
    },
    "options": {
      "idConflictPolicy": "remap",
      "outsideEndpointPolicy": "reject",
      "preserveRelativePositions": true
    }
  }
}
