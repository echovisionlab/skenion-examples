{
  "schema": "skenion.node.definition",
  "schemaVersion": "0.2.0",
  "id": "core.event-log",
  "version": "0.2.0",
  "displayName": "Event Log",
  "category": "Core",
  "ports": [
    {
      "id": "in",
      "direction": "input",
      "type": "event.bang",
      "rate": "event",
      "maxConnections": 8,
      "mergePolicy": "ordered-events",
      "triggerMode": "trigger"
    }
  ],
  "execution": {
    "model": "event"
  },
  "state": {
    "persistent": true
  },
  "permissions": [],
  "capabilities": ["event.bang.v0.2"]
}
