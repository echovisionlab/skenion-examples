{
  "schema": "skenion.node.definition",
  "schemaVersion": "0.2.0",
  "id": "adapter.gpu-texture-to-render-frame",
  "version": "0.2.0",
  "displayName": "GPU Texture to Render Frame",
  "category": "Adapter",
  "ports": [
    {
      "id": "texture",
      "direction": "input",
      "type": "gpu.texture2d",
      "rate": "gpu"
    },
    {
      "id": "frame",
      "direction": "output",
      "type": "render.frame",
      "rate": "render"
    }
  ],
  "execution": {
    "model": "gpu_pass",
    "clock": "frame"
  },
  "state": {
    "persistent": false
  },
  "permissions": [],
  "capabilities": ["adapter.explicit.v0.2"]
}
