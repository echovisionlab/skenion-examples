{
  "schema": "skenion.runtime.session-smoke.fixture",
  "schemaVersion": "0.1.0",
  "scenario": "separate-session-isolation",
  "title": "Explicit sessions keep graph, history, and control state isolated",
  "description": "Loads two explicit sessions, mutates and controls only the first, then checks the second session's graph revision, history, and control revision did not change.",
  "runtime": {
    "requiresCapabilities": [
      "session.load",
      "session.project",
      "session.addressing",
      "session.mutate",
      "session.history",
      "session.control.event",
      "session.control.state"
    ]
  },
  "sessions": [
    {
      "role": "primary",
      "id": "m06-8-isolation-primary-{runId}",
      "project": "compatibility/unsupported/pre-consolidation-v0.1/projects/valid/minimal-value.project.json",
      "patch": "compatibility/unsupported/pre-consolidation-v0.1/patches/valid/set-value-param.patch.json",
      "controlEvent": {
        "nodeId": "value_1",
        "portId": "in",
        "message": {
          "selector": "set",
          "atoms": [
            {
              "type": "float",
              "representation": "f32",
              "value": 7
            }
          ]
        }
      },
      "expectedGraphId": "minimal-value-graph",
      "expectedGraphRevisionAfterPatch": "2"
    },
    {
      "role": "secondary",
      "id": "m06-8-isolation-secondary-{runId}",
      "project": "compatibility/unsupported/pre-consolidation-v0.1/projects/valid/fullscreen-shader.project.json",
      "expectedGraphId": "fullscreen-shader-render-graph",
      "expectedGraphRevision": "1",
      "expectedHistoryEntries": 0,
      "expectedControlRevision": 0
    }
  ],
  "expect": {
    "isolatedSnapshots": true,
    "isolatedHistory": true,
    "isolatedControlState": true
  }
}
