{
  "schema": "skenion.runtime.session-smoke.fixture",
  "schemaVersion": "0.1.0",
  "scenario": "sidecar-handshake-health",
  "title": "Sidecar startup and health handshake",
  "description": "Checks the local-managed sidecar startup payload, sidecar health payload, and generic runtime health endpoint used by desktop hosts before connecting windows.",
  "runtime": {
    "requiresCapabilities": [
      "runtime.sidecar.startup",
      "runtime.sidecar.health"
    ]
  },
  "paths": {
    "runtimeHealth": "/health",
    "startup": "/v0/sidecar/startup",
    "sidecarHealth": "/v0/sidecar/health"
  },
  "expect": {
    "runtimeService": "skenion-runtime",
    "defaultSessionId": "default",
    "defaultSessionPath": "/v0/sessions/default",
    "startupSchema": "skenion.runtime.sidecar.startup",
    "healthSchema": "skenion.runtime.sidecar.health",
    "readiness": "ready",
    "shutdownScope": "owned-child-only"
  }
}
