          "id": "speed",
          "direction": "input",
          "label": "Speed",
          "type": {
            "flow": "value",
            "dataKind": "number.f32",
            "range": {
              "min": 0,
              "max": 2,
              "step": 0.01
            }
          },
          "required": false,
          "activation": "latched",
          "default": 0.75
        },
