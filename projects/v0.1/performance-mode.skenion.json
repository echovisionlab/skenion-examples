        "kind": "core.comment",
        "kindVersion": "0.1.0",
        "params": {
          "text": "Open this project, switch to Performance Mode, load the current graph into Runtime, start preview, then move Speed and Enabled controls. Performance controls send runtime control events and do not create graph patches."
        },
        "ports": []
      },
