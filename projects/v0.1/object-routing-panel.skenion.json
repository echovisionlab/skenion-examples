      {
        "id": "shader_1",
        "kind": "render.fullscreen-shader",
        "kindVersion": "0.1.0",
        "params": {
          "language": "wgsl",
          "source": "// @skenion.uniform speed number.float default=0.75 min=0 max=2 step=0.01\n// @skenion.uniform enabled boolean default=true\n@fragment\nfn fs_main() -> @location(0) vec4<f32> {\n  let pulse = 0.5 + 0.5 * sin(skenion.time * skenion.speed);\n  let active = vec4<f32>(pulse, skenion.speed / 2.0, 1.0 - pulse, 1.0);\n  return select(vec4<f32>(0.04, 0.04, 0.04, 1.0), active, sk_bool(skenion.enabled));\n}"
        },
