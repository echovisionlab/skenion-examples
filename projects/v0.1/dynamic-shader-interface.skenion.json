      {
        "id": "shader_1",
        "kind": "render.fullscreen-shader",
        "kindVersion": "0.1.0",
        "params": {
          "language": "wgsl",
          "source": "// @skenion.uniform speed number.float default=0.5 min=0 max=2 step=0.01\n// @skenion.uniform enabled boolean default=true\n// @skenion.uniform iterations number.int default=8\n// @skenion.uniform tint color default=[1,0.2,0.1,1]\n@fragment\nfn fs_main() -> @location(0) vec4<f32> {\n  let enabled = sk_bool(skenion.enabled);\n  let bands = max(f32(skenion.iterations), 1.0);\n  let pulse = 0.5 + 0.5 * sin(skenion.time * skenion.speed + bands * 0.05);\n  let base = vec4<f32>(pulse, skenion.speed / 2.0, 1.0 - pulse, 1.0) * skenion.tint;\n  return select(vec4<f32>(0.02, 0.02, 0.02, 1.0), base, enabled);\n}"
        },
